---
import "../styles/global.css";

const { title = "Novel Title", chapter = "Chapter _", prevFilePath = "../" } = Astro.props;
---

<div>
    <nav class="flex flex-row justify-between items-center p-3 pr-12 bg-gradient-to-t from-blue-300 to-blue-700 
    dark:from-slate-900 dark:to-stone-950 dark:text-gray-300 border-b border-slate-700">
        <h1 class="pt-1 text-xl">
            <a class="hover:text-gray-700 dark:hover:text-gray-400" href={prevFilePath}>{title}</a> / {chapter}
        </h1>
        <div id="links" class="flex flex-row space-x-4 pt-1">
            <a href="/profile-website/writing/writing" class="hover:text-gray-700 dark:hover:text-gray-400">Writing</a>
        </div>
    </nav>
</div>
